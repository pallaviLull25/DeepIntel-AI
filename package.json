{
  "name": "intel-atlas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:client\"",
    "dev:api": "./scripts/run-api.sh --host 0.0.0.0 --port 3001 --reload",
    "dev:client": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "npm run build && NODE_ENV=production ./scripts/run-api.sh --host 0.0.0.0 --port 3000",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "eval:research": "python3 -m backend.evals.runner"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
